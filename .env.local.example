# Analytics opcional. Los scripts solo cargan si estas variables están seteadas
# y el usuario aceptó el ConsentBanner.
# GA4: https://analytics.google.com → Administrar → Flujos de datos
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# Meta Pixel: https://business.facebook.com/events_manager
NEXT_PUBLIC_META_PIXEL_ID=XXXXXXXXXXXXXXXXXX
