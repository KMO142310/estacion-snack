# Supabase — get from https://supabase.com/dashboard/project/<project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Admin auth — email that can log in to /admin
ADMIN_EMAIL=tu@email.com

# Site canonical URL (used for OG tags and /pedido/[id] links)
NEXT_PUBLIC_SITE_URL=https://estacionsnack.cl

# Cron secret — Bearer token required to invoke /api/cron/release-reservations.
# Generate with: openssl rand -hex 32
CRON_SECRET=change-me

# Audit pepper — server-side secret used to hash IPs and User-Agents before
# writing them to audit_log_order_views. Never use raw IPs (GDPR §5.1.c).
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# Rotate invalidates historical correlations but does NOT expose PII.
# Used by /pedido/[id]: if missing, the audit row is skipped (console.error)
# and the page still renders normally — customer experience is not degraded
# by an operator-side misconfig. Set this in Vercel env for observability.
AUDIT_PEPPER=

# Analytics — optional, scripts only load when these are set.
# GA4: https://analytics.google.com → Administrar → Flujos de datos → ID de medición
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# Meta Pixel: https://business.facebook.com/events_manager → Píxeles → ID del píxel
NEXT_PUBLIC_META_PIXEL_ID=XXXXXXXXXXXXXXXXXX
