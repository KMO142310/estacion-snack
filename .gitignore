# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
*.key
*.crt
*.p12
*.pfx
id_rsa*
id_ed25519*
credentials.json
service-account*.json

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — belt and suspenders: explicit names AND glob
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local
.env.backup*
# keep the example
!.env.local.example

# vercel (linked project config, contains projectId/orgId)
.vercel
.vercel/

# supabase CLI temp/local state
supabase/.temp/
supabase/.branches/

# typescript
*.tsbuildinfo
next-env.d.ts

# claude code local state — trackear solo agents/ y settings, no scratchpad
.claude/scratch/

# Playwright
test-results/
playwright-report/
playwright/.cache/
